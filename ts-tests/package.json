{
  "name": "codex-twist-ffi-tests",
  "version": "1.0.0",
  "description": "Real FFI tests for codex-twist - napi-rs bindings",
  "scripts": {
    "build": "cd ../crates/codex-twist && cargo build --release --features napi",
    "build:napi": "cd ../crates/codex-twist && napi build --platform --release",
    "test": "jest",
    "test:real": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20",
    "jest": "^29",
    "@jest/globals": "^29",
    "ts-jest": "^29",
    "typescript": "^5"
  },
  "dependencies": {
    "@napi-rs/cli": "^2"
  }
}
