{
  "all": true,
  "src": ["dist/mcp/"],
  "include": ["dist/**/*.js", "dist/**/*.mjs"],
  "exclude": [
    "tests/**",
    "coverage/**",
    "node_modules/**",
    "src/**",
    "**/*.test.js",
    "**/*.test.mjs",
    "**/*.spec.js",
    "**/*.spec.mjs"
  ],
  "reporter": ["text", "lcov", "html"],
  "reporterOptions": {
    "lcov": {
      "projectRoot": "."
    }
  },
  "temp-directory": "./coverage/.tmp",
  "clean": true,
  "skip-full": false,
  "check-coverage": false,
  "lines": 90,
  "branches": 85,
  "functions": 95,
  "statements": 90
}
