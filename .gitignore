# Hajimi V3 - Node.js .gitignore
# 基于 GitHub Node.js.gitignore 标准模板

# 依赖目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# 环境变量文件（敏感信息）
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# 日志文件
logs/
*.log
*.log.*

# 运行时数据
pids/
*.pid
*.seed
*.pid.lock

# 测试覆盖率
coverage/
.nyc_output/

# 构建输出
dist/
build/
*.tsbuildinfo

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE 和编辑器
.vscode/
.idea/
*.swp
*.swo
*~.cache/

# 临时文件
temp/
tmp/
*.tmp

# ============================================
# Rust 构建产物（2026-03-28 添加）
# ============================================
# Cargo构建输出
target/
crates/*/target/
crates/**/target/

# Rust特定文件
**/*.rlib
**/*.rmeta
**/*.crate
Cargo.lock.bak

# ============================================
# WASM 构建产物（2026-03-28 添加）
# ============================================
src/wasm/target/
src/wasm/pkg/*.wasm
src/wasm/pkg/*.js
src/wasm/pkg/*.ts

# ============================================
# TypeScript FFI测试依赖（2026-03-28 添加）
# ============================================
ts-tests/node_modules/
ts-tests/package-lock.json
ts-tests/*.log

# ============================================
# 大型测试夹具（考虑使用Git LFS）
# ============================================
tests/fixtures/*.bin
tests/fixtures/*.dat
tests/fixtures/*.db
tests/fixtures/large-*

# ============================================
# 本地数据目录（用户数据）
# ============================================
data/
hctx-cache/
.hajimi/
*.db
*.db-journal
*.db-wal

# ============================================
# 编译产物和中间文件
# ============================================
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.pdb
*.ilk

# ============================================
# IDE/编辑器配置（本地环境）
# ============================================
.claude/
.config/

# ============================================
# Agent提示词（本地协作配置）
# ============================================
Agent prompt/

# ============================================
# 归档历史（完全忽略）
# ============================================
archive/

# ============================================
# Fork的子项目
# ============================================
/codex-twist/  # 根目录的fork子项目
crates/*/target/  # 但保留crates/hajimi-codex-twist/
archive/**/*.log
archive/**/*.tmp

# ============================================
# 日志文件
# ============================================
logs/
*.log

# ============================================
# 覆盖率报告（CI生成）
# ============================================
coverage/

# ============================================
# 内部文档（不对外公开）
# ============================================
docs/

# ============================================
# 脚本编译产物
# ============================================
scripts/*.exe
scripts/*.pdb

# ============================================
# 内部工作流（本地任务管理）
# ============================================
task/
task-audit/
templates/
audit-report/
audit report/

# ============================================
# 过时技术栈内容（已清理）
# ============================================
ts-tests/
contracts/
docker/

# ============================================
# 其他
# ============================================
*.bak
*.orig
*.rej
*~
