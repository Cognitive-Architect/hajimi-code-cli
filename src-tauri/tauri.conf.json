{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hajimi",
  "version": "0.1.0",
  "identifier": "com.hajimi.desktop",
  "build": {
    "frontendDist": "../src/interface/web",
    "devUrl": "http://localhost:3456",
    "beforeDevCommand": "cd src/interface/web && python -m http.server 3456",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hajimi",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
