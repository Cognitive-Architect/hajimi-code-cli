//! Cloud记忆�?- E2EE端到端加密架�?(DEBT-CLOUD-001)
//! Age加密(X25519) + Argon2id(t=3,m=64MB,p=4) + Scrypt降级
use crate::types::{MemoryLayer, MemoryLayerId};
use age::secrecy::ExposeSecret;
use argon2::Argon2;
use std::io::{Read, Write};
use thiserror::Error;
use zeroize::{Zeroize, ZeroizeOnDrop};
/// Argon2id参数 - 地狱红线：t=3, m=64MB, p=4
pub const KEY_ITERATIONS: u32 = 3;
pub const MEMORY_COST_KIB: u32 = 65536;
pub const PARALLELISM: u32 = 4;
pub const CHUNK_SIZE: usize = 1024 * 1024;
/// 密钥版本常量
pub const KEY_VERSION_V1: u32 = 1;
pub const KEY_VERSION_CURRENT: u32 = 2;
/// Cloud身份 - X25519密钥对（Zeroize保护�?
#[derive(Zeroize, ZeroizeOnDrop)]
pub struct CloudIdentity {
    #[zeroize(skip)]
    pub public_key: String,
    secret_key: Vec<u8>,
    pub key_version: u32,
}
impl CloudIdentity {
    pub fn public_key(&self) -> &str { &self.public_key }
    pub fn version(&self) -> u32 { self.key_version }
}
#[derive(Debug, Clone)]
pub struct EncryptedChunk {
    pub data: Vec<u8>,
    pub index: u32,
    pub is_last: bool,
    pub key_version: u32,
}
#[derive(Debug, Clone)]
pub struct CloudSyncMeta {
    pub entry_id: String,
    pub chunk_count: u32,
    pub total_size: u64,
    pub key_version: u32,
}
#[derive(Debug, Error)]
pub enum CloudError {
    #[error("Encryption: {0}")] EncryptionError(String),
    #[error("Decryption: {0}")] DecryptionError(String),
    #[error("Integrity check failed")] IntegrityError,
    #[error("KDF: {0}")] KdfError(String),
    #[error("Invalid password")] InvalidPassword,
    #[error("Sync failed: {0}")] SyncFailed(String),
    #[error("Key version mismatch: {0}")] KeyVersionError(String),
    #[error("Degraded mode: {0}")] DegradedMode(String),
}
pub type ProgressCallback = Box<dyn Fn(u64, u64) + Send + Sync>;
/// 生成离线X25519身份密钥对（带版本）
pub fn generate_identity() -> Result<CloudIdentity, CloudError> {
    let secret = age::x25519::Identity::generate();
    let public = secret.to_public();
    let secret_bytes = secret.to_string().expose_secret().as_bytes().to_vec();
    Ok(CloudIdentity { public_key: public.to_string(), secret_key: secret_bytes, key_version: KEY_VERSION_CURRENT })
}
/// 生成V1版本密钥（向后兼容）
pub fn generate_identity_v1() -> Result<CloudIdentity, CloudError> {
    let secret = age::x25519::Identity::generate();
    let public = secret.to_public();
    let secret_bytes = secret.to_string().expose_secret().as_bytes().to_vec();
    Ok(CloudIdentity { public_key: public.to_string(), secret_key: secret_bytes, key_version: KEY_VERSION_V1 })
}
/// Argon2id密钥派生（t=3, m=64MB, p=4�?
pub fn derive_key(password: &str, salt: &[u8]) -> Result<[u8; 32], CloudError> {
    let argon2 = Argon2::new(
        argon2::Algorithm::Argon2id,
        argon2::Version::V0x13,
        argon2::Params::new(MEMORY_COST_KIB, KEY_ITERATIONS, PARALLELISM, Some(32))
            .map_err(|e| CloudError::KdfError(e.to_string()))?,
    );
    let mut key = [0u8; 32];
    argon2.hash_password_into(password.as_bytes(), salt, &mut key)
        .map_err(|e| CloudError::KdfError(e.to_string()))?;
    Ok(key)
}
/// Scrypt降级KDF（Argon2内存不足时使用）
pub fn derive_key_scrypt(password: &str, salt: &[u8]) -> Result<[u8; 32], CloudError> {
    use scrypt::{scrypt, Params};
    let params = Params::new(20, 8, 1, 32).map_err(|e| CloudError::KdfError(e.to_string()))?;
    let mut key = [0u8; 32];
    scrypt(password.as_bytes(), salt, &params, &mut key).map_err(|e| CloudError::KdfError(e.to_string()))?;
    Ok(key)
}
/// 带降级的密钥派生（CRYPTO-003熔断预案�?
pub fn derive_key_with_fallback(password: &str, salt: &[u8]) -> Result<([u8; 32], bool), CloudError> {
    match derive_key(password, salt) {
        Ok(key) => Ok((key, false)),
        Err(_) => {
            let key = derive_key_scrypt(password, salt)?;
            Ok((key, true))
        }
    }
}
/// 验证Argon2参数
pub fn verify_argon2_params() -> (u32, u32, u32) {
    (KEY_ITERATIONS, MEMORY_COST_KIB, PARALLELISM)
}
/// Age加密分块（带密钥版本�?
pub fn encrypt_chunk(plaintext: &[u8], recipient: &age::x25519::Recipient) -> Result<Vec<u8>, CloudError> {
    let encryptor = age::Encryptor::with_recipients(vec![Box::new(recipient.clone())])
        .ok_or_else(|| CloudError::EncryptionError("No recipients".to_string()))?;
    let mut encrypted = Vec::new();
    let mut writer = encryptor.wrap_output(&mut encrypted)
        .map_err(|e| CloudError::EncryptionError(e.to_string()))?;
    writer.write_all(plaintext).map_err(|e| CloudError::EncryptionError(e.to_string()))?;
    writer.finish().map_err(|e| CloudError::EncryptionError(e.to_string()))?;
    Ok(encrypted)
}
/// Age解密分块
pub fn decrypt_chunk(ciphertext: &[u8], identity: &age::x25519::Identity) -> Result<Vec<u8>, CloudError> {
    let decryptor = age::Decryptor::new(ciphertext)
        .map_err(|e| CloudError::DecryptionError(e.to_string()))?;
    let mut decrypted = Vec::new();
    match decryptor {
        age::Decryptor::Recipients(d) => {
            let mut reader = d.decrypt(std::iter::once(identity as &dyn age::Identity))
                .map_err(|e| CloudError::DecryptionError(e.to_string()))?;
            reader.read_to_end(&mut decrypted).map_err(|e| CloudError::DecryptionError(e.to_string()))?;
        }
        _ => return Err(CloudError::DecryptionError("Unexpected decryptor type".to_string())),
    }
    Ok(decrypted)
}
/// 向后兼容解密V1版本（CRYPTO-004熔断预案�?
pub fn decrypt_legacy(ciphertext: &[u8], identity_v1: &age::x25519::Identity) -> Result<Vec<u8>, CloudError> {
    decrypt_chunk(ciphertext, identity_v1).map_err(|e| CloudError::KeyVersionError(format!("V1 decrypt failed: {}", e)))
}
/// 常量时间比较（防侧信道）
pub fn constant_time_verify(a: &[u8], b: &[u8]) -> bool {
    use subtle::ConstantTimeEq;
    a.ct_eq(b).unwrap_u8() == 1
}
/// Cloud记忆层E2EE实现
pub struct CloudMemory {
    identity: Option<CloudIdentity>,
    device_id: String,
    progress_callback: Option<ProgressCallback>,
    sync_meta: Option<CloudSyncMeta>,
    degraded_mode: bool,
}
impl CloudMemory {
    pub fn new(device_id: impl Into<String>) -> Self {
        Self { identity: None, device_id: device_id.into(), progress_callback: None, sync_meta: None, degraded_mode: false }
    }
    pub fn initialize_identity(&mut self) -> Result<(), CloudError> {
        self.identity = Some(generate_identity()?); Ok(())
    }
    pub fn set_progress_callback(&mut self, cb: ProgressCallback) { self.progress_callback = Some(cb); }
    pub fn public_key(&self) -> Option<&str> { self.identity.as_ref().map(|i| i.public_key()) }
    pub fn is_degraded(&self) -> bool { self.degraded_mode }
    pub fn enable_degraded_mode(&mut self) { self.degraded_mode = true; }
    /// 流式加密�?MB分块，带密钥版本�?
    pub fn encrypt_stream(&self, data: &[u8], recipient: &age::x25519::Recipient) -> Result<Vec<EncryptedChunk>, CloudError> {
        let total = data.len() as u64;
        let chunks: Vec<&[u8]> = data.chunks(CHUNK_SIZE).collect();
        let mut result = Vec::with_capacity(chunks.len());
        let key_version = self.identity.as_ref().map(|i| i.key_version).unwrap_or(KEY_VERSION_CURRENT);
        for (idx, chunk) in chunks.iter().enumerate() {
            let encrypted = encrypt_chunk(chunk, recipient)?;
            if let Some(ref cb) = self.progress_callback {
                let processed = ((idx + 1) * CHUNK_SIZE) as u64;
                cb(processed.min(total), total);
            }
            result.push(EncryptedChunk { data: encrypted, index: idx as u32, is_last: idx == chunks.len() - 1, key_version });
        }
        Ok(result)
    }
    /// 流式解密（支持向后兼容）
    pub fn decrypt_stream(&self, chunks: &[EncryptedChunk], identity: &age::x25519::Identity) -> Result<Vec<u8>, CloudError> {
        let total = chunks.len();
        let mut result = Vec::with_capacity(total * CHUNK_SIZE);
        for (idx, chunk) in chunks.iter().enumerate() {
            let decrypted = if chunk.key_version == KEY_VERSION_V1 {
                decrypt_legacy(&chunk.data, identity)?
            } else {
                decrypt_chunk(&chunk.data, identity)?
            };
            result.extend_from_slice(&decrypted);
            if let Some(ref cb) = self.progress_callback {
                let processed = ((idx + 1) * CHUNK_SIZE) as u64;
                cb(processed, (total * CHUNK_SIZE) as u64);
            }
        }
        Ok(result)
    }
    /// WebRTC DataChannel同步准备（带密钥版本�?
    pub fn prepare_for_sync(&mut self, chunks: &[EncryptedChunk]) -> Result<(), CloudError> {
        if chunks.is_empty() { return Err(CloudError::SyncFailed("Empty".to_string())); }
        let total_size: usize = chunks.iter().map(|c| c.data.len()).sum();
        let key_version = chunks.first().map(|c| c.key_version).unwrap_or(KEY_VERSION_CURRENT);
        self.sync_meta = Some(CloudSyncMeta {
            entry_id: format!("sync_{}", self.device_id),
            chunk_count: chunks.len() as u32,
            total_size: total_size as u64,
            key_version,
        });
        Ok(())
    }
}
impl MemoryLayer for CloudMemory {
    fn layer_id(&self) -> MemoryLayerId { MemoryLayerId::Cloud }
    fn capacity(&self) -> usize { usize::MAX }
}
#[cfg(test)]
mod tests {
    use super::*;
    #[test]
    fn test_key_generation_offline() {
        let id = generate_identity().unwrap();
        assert!(id.public_key().starts_with("age1"));
        assert_eq!(id.key_version, KEY_VERSION_CURRENT);
    }
    #[test]
    fn test_encrypt_decrypt_roundtrip() {
        let identity = age::x25519::Identity::generate();
        let recipient = identity.to_public();
        let plaintext = "Hello E2EE! End-to-end encryption test";
        let encrypted = encrypt_chunk(plaintext.as_bytes(), &recipient).unwrap();
        assert_ne!(encrypted, plaintext.as_bytes().to_vec());
        let decrypted = decrypt_chunk(&encrypted, &identity).unwrap();
        assert_eq!(decrypted, plaintext.as_bytes().to_vec());
    }
    #[test]
    fn test_chunked_encryption_stream() {
        let mut mem = CloudMemory::new("test");
        mem.initialize_identity().unwrap();
        let data = vec![0x42u8; 1024 * 1024];
        let identity = age::x25519::Identity::generate();
        let chunks = mem.encrypt_stream(&data, &identity.to_public()).unwrap();
        assert_eq!(chunks[0].key_version, KEY_VERSION_CURRENT);
        let decrypted = mem.decrypt_stream(&chunks, &identity).unwrap();
        assert_eq!(decrypted.len(), data.len());
    }
    #[test]
    fn test_argon2_params_enforced() {
        let (t, m, p) = verify_argon2_params();
        assert!(t >= 3 && m >= 65536 && p >= 4, "Argon2 param below threshold");
    }
    #[test]
    fn test_wrong_password_fails() {
        let salt: [u8; 16] = rand::random();
        let k1 = derive_key("correct", &salt).unwrap();
        let k2 = derive_key("wrong", &salt).unwrap();
        assert_ne!(k1.to_vec(), k2.to_vec());
    }
    #[test]
    fn test_corrupted_ciphertext_detection() {
        let id = age::x25519::Identity::generate();
        let mut enc = encrypt_chunk(b"secret", &id.to_public()).unwrap();
        let len = enc.len();
        if len > 0 { enc[len/2] ^= 0xFF; }
        assert!(decrypt_chunk(&enc, &id).is_err());
    }
    #[test]
    fn test_key_leakage_zeroize() {
        let id = generate_identity().unwrap();
        drop(id);
    }
    #[test]
    fn test_progress_callback_encryption() {
        let mut mem = CloudMemory::new("test");
        mem.initialize_identity().unwrap();
        let cnt = std::sync::Arc::new(std::sync::atomic::AtomicU32::new(0));
        let c = cnt.clone();
        mem.set_progress_callback(Box::new(move |cur, _| { if cur > 0 { c.fetch_add(1, std::sync::atomic::Ordering::SeqCst); } }));
        let data = vec![0u8; 2 * 1024 * 1024];
        let id = age::x25519::Identity::generate();
        mem.encrypt_stream(&data, &id.to_public()).unwrap();
        assert!(cnt.load(std::sync::atomic::Ordering::SeqCst) >= 1);
    }
    #[test]
    fn test_cloud_sync_encrypted() {
        let mut mem = CloudMemory::new("test_device");
        mem.initialize_identity().unwrap();
        let data = b"WebRTC sync data";
        let id = age::x25519::Identity::generate();
        let chunks = mem.encrypt_stream(data, &id.to_public()).unwrap();
        mem.prepare_for_sync(&chunks).unwrap();
        let decrypted = mem.decrypt_stream(&chunks, &id).unwrap();
        assert_eq!(decrypted, data.to_vec());
    }
    #[test]
    fn test_side_channel_resistance() {
        assert!(constant_time_verify(b"abc", b"abc"));
        assert!(!constant_time_verify(b"abc", b"xyz"));
    }
    #[test]
    fn test_key_rotation_compatibility() {
        let old_id = age::x25519::Identity::generate();
        let pt = b"Historical data";
        let enc = encrypt_chunk(pt, &old_id.to_public()).unwrap();
        assert_eq!(decrypt_chunk(&enc, &old_id).unwrap(), pt.to_vec());
    }
    #[test]
    fn test_key_version_management() {
        let id_v1 = generate_identity_v1().unwrap();
        let id_v2 = generate_identity().unwrap();
        assert_eq!(id_v1.key_version, KEY_VERSION_V1);
        assert_eq!(id_v2.key_version, KEY_VERSION_CURRENT);
    }
    #[test]
    fn test_decrypt_v0_compatibility() {
        let identity = age::x25519::Identity::generate();
        let plaintext = b"Backward compatible data";
        let encrypted = encrypt_chunk(plaintext, &identity.to_public()).unwrap();
        let decrypted = decrypt_legacy(&encrypted, &identity).unwrap();
        assert_eq!(decrypted, plaintext.to_vec());
    }
    #[test]
    fn test_argon2_failure_degradation() {
        let salt: [u8; 16] = rand::random();
        let (key, degraded) = derive_key_with_fallback("password", &salt).unwrap();
        assert_eq!(key.len(), 32);
        assert!(!degraded); // Normal case should not degrade
        // Test Scrypt directly
        let scrypt_key = derive_key_scrypt("password", &salt).unwrap();
        assert_eq!(scrypt_key.len(), 32);
    }
    #[test]
    fn test_degraded_mode_flag() {
        let mut mem = CloudMemory::new("test");
        assert!(!mem.is_degraded());
        mem.enable_degraded_mode();
        assert!(mem.is_degraded());
    }
}
