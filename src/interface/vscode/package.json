{
  "name": "hajimi-code-cli",
  "displayName": "Hajimi Code CLI",
  "description": "VSCode extension for Hajimi",
  "version": "1.0.0",
  "publisher": "hajimi",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:hajimi.openSidebar"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hajimi.openSidebar",
        "title": "Open Web UI",
        "category": "Hajimi"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
